[Unit]
Description=StoryGraph Activity Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=storygraph-bot
WorkingDirectory=/opt/storygraph-bot
EnvironmentFile=/opt/storygraph-bot/.env
ExecStart=/opt/storygraph-bot/.venv/bin/python bot.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target

